# Mapbox アクセストークン - https://account.mapbox.com/tokens/ で取得してください
VITE_MAPBOX_ACCESS_TOKEN=dummy_mapbox_token

# アプリケーション認証パスワード（空の場合は認証をスキップ）
VITE_APP_PASSWORD=

# OpenAI API設定 - Storybook AIコンシェルジュ用
# 2026年現在の推奨モデル: gpt-5-mini, gpt-5-nano, gemini-flash-2.5 など
VITE_OPENAI_API_KEY=your_openai_api_key_here
VITE_OPENAI_MODEL=gpt-5-mini

# GitHub トークン - https://github.com/settings/tokens で取得してください
GITHUB_TOKEN=dummy_github_token

# Chromatic プロジェクトトークン - https://www.chromatic.com で取得してください
CHROMATIC_PROJECT_TOKEN=dummy_chromatic_token
