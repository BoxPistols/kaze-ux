{
  "name": "kaze-ux",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/kaze-ux.git"
  },
  "private": false,
  "description": "A modern React design system built with MUI v7, Tailwind CSS, and Storybook",
  "keywords": [
    "react",
    "mui",
    "theme",
    "components",
    "ui",
    "design-system",
    "storybook",
    "tailwindcss"
  ],
  "author": "",
  "license": "MIT",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "dev:all": "pnpm dev & pnpm storybook & pnpm -F saas-dashboard dev & pnpm -F ubereats-clone dev & pnpm -F sky-kaze dev & wait",
    "dev:docs": "pnpm dev & pnpm storybook & wait",
    "build": "echo 'Build skipped - using source files directly'",
    "build-sandbox": "vite build --mode sandbox",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:all": "vitest run --coverage --reporter=basic --reporter=html",
    "test:all:ui": "vitest --ui --coverage --reporter=basic --reporter=html",
    "test:all:watch": "vitest --coverage --reporter=basic",
    "format": "prettier --write .",
    "lint": "eslint --fix ./src",
    "fix": "pnpm run lint && pnpm run format",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "build-all": "pnpm run build-storybook",
    "build:gh-pages": "vite build --mode gh-pages",
    "build:gh-pages:storybook": "storybook build -o gh-pages/storybook",
    "build:gh-pages:all": "pnpm run build:gh-pages:storybook && pnpm run build:gh-pages:dashboard && pnpm run build:gh-pages:ubereats && pnpm run build:gh-pages:sky-kaze",
    "prepare": "husky",
    "export-tokens": "tsx scripts/export-design-tokens.ts",
    "export-tokens:auto": "npx tsx packages/system-design-export/src/cli.ts --from mui --input src/themes/theme.ts",
    "figma-plugin:build": "esbuild figma-plugin/code.ts --bundle --outfile=figma-plugin/code.js --target=es2017 --format=iife",
    "figma-plugin:watch": "esbuild figma-plugin/code.ts --bundle --outfile=figma-plugin/code.js --target=es2017 --format=iife --watch",
    "figma:sync": "pnpm export-tokens && pnpm figma-plugin:build",
    "push-tokens-to-figma": "tsx scripts/push-tokens-to-figma.ts",
    "storybook:capture": "tsx scripts/storybook-capture.ts",
    "dev:dashboard": "pnpm --filter saas-dashboard dev",
    "dev:ubereats": "pnpm --filter ubereats-clone dev",
    "build:dashboard": "pnpm --filter saas-dashboard build",
    "build:ubereats": "pnpm --filter ubereats-clone build",
    "build:gh-pages:dashboard": "pnpm --filter saas-dashboard build:gh-pages",
    "build:gh-pages:ubereats": "pnpm --filter ubereats-clone build:gh-pages",
    "preview:dashboard": "pnpm --filter saas-dashboard preview",
    "preview:ubereats": "pnpm --filter ubereats-clone preview",
    "test:dashboard": "pnpm --filter saas-dashboard test",
    "test:ubereats": "pnpm --filter ubereats-clone test",
    "dev:sky-kaze": "pnpm --filter sky-kaze dev",
    "build:sky-kaze": "pnpm --filter sky-kaze build",
    "build:gh-pages:sky-kaze": "pnpm --filter sky-kaze build:gh-pages",
    "preview:sky-kaze": "pnpm --filter sky-kaze preview"
  },
  "peerDependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/material": "^7.2.0",
    "@mui/system": "^7.3.9",
    "react": "^18.3.1",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@mapbox/togeojson": "^0.16.2",
    "@mui/icons-material": "^7.3.9",
    "@mui/lab": "7.0.1-beta.23",
    "@mui/system": "^7.3.9",
    "@mui/x-data-grid": "^8.28.2",
    "@mui/x-date-pickers": "^8.27.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@turf/turf": "^7.3.4",
    "@types/maplibre-gl": "^1.14.0",
    "@types/react-router-dom": "^5.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "framer-motion": "^12.38.0",
    "fuse.js": "^7.3.0",
    "lucide-react": "^0.577.0",
    "map-or-similar": "^1.5.0",
    "mapbox-gl": "^3.21.0",
    "maplibre-gl": "^4.7.1",
    "memoizerific": "^1.11.3",
    "prism-react-renderer": "^2.4.1",
    "prop-types": "^15.8.1",
    "rbush": "^4.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "remark-gfm": "^4.0.1",
    "sass": "^1.99.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.1",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@figma/plugin-typings": "^1.124.0",
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "@storybook/addon-a11y": "^10.3.4",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-links": "^10.3.4",
    "@storybook/addon-mcp": "^0.5.0",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@storybook/theming": "^8.6.14",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/node": "^20.19.39",
    "@types/rbush": "^4.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "^10.4.27",
    "esbuild": ">=0.28.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^10.3.4",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "react-map-gl": "^7.1.9",
    "storybook": "^10.3.4",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "turbo": "^2.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm run lint"
    ],
    "*.{css,scss,json,md}": [
      "pnpm run format"
    ]
  },
  "packageManager": "pnpm@10.2.1",
  "volta": {
    "node": "22.14.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
