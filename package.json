{
  "name": "sdpf-theme",
  "repository": {
    "type": "git",
    "url": "https://github.com/KDDIsmartdrone-dev/sdpf-theme.git"
  },
  "private": true,
  "description": "KDDI Smart Drone Platform UI theme components",
  "keywords": [
    "react",
    "mui",
    "theme",
    "components",
    "ui",
    "kddi",
    "drone"
  ],
  "author": "KDDI Smart Drone",
  "license": "UNLICENSED",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "echo 'Build skipped - using source files directly'",
    "build-sandbox": "vite build --mode sandbox",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:all": "vitest run --coverage --reporter=basic --reporter=html",
    "test:all:ui": "vitest --ui --coverage --reporter=basic --reporter=html",
    "test:all:watch": "vitest --coverage --reporter=basic",
    "format": "prettier --write .",
    "lint": "eslint --fix ./src",
    "fix": "npm run lint && npm run format",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "build-all": "pnpm run build-storybook",
    "build:gh-pages": "vite build --mode gh-pages",
    "build:gh-pages:storybook": "storybook build -o gh-pages/storybook",
    "build:gh-pages:all": "pnpm run build:gh-pages && pnpm run build:gh-pages:storybook",
    "build:gh-pages:inject-auth": "node scripts/inject-auth.js",
    "prepare": "husky",
    "chromatic": "npx chromatic --project-token=$CHROMATIC_PROJECT_TOKEN",
    "export-tokens": "tsx scripts/export-design-tokens.ts",
    "export-story-catalog": "tsx scripts/generate-story-catalog.ts"
  },
  "peerDependencies": {
    "@emotion/react": "^11.13.5",
    "@emotion/styled": "^11.13.5",
    "@mui/material": "^7.2.0",
    "@mui/system": "^7.3.8",
    "react": "^18.3.1",
    "react-dom": "^18.2.0"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.1",
    "@mapbox/mapbox-gl-draw": "^1.5.1",
    "@mapbox/togeojson": "^0.16.2",
    "@mui/icons-material": "^7.3.8",
    "@mui/lab": "7.0.1-beta.22",
    "@mui/system": "^7.3.8",
    "@mui/x-data-grid": "^8.27.3",
    "@mui/x-date-pickers": "^8.27.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@turf/turf": "^7.3.4",
    "@types/maplibre-gl": "^1.14.0",
    "@types/react-router-dom": "^5.3.3",
    "class-variance-authority": "^0.7.1",
    "cli-table3": "^0.6.5",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.19",
    "framer-motion": "^12.34.3",
    "fuse.js": "^7.1.0",
    "init": "^0.1.2",
    "lucide-react": "^0.575.0",
    "map-or-similar": "^1.5.0",
    "mapbox-gl": "^3.19.0",
    "maplibre-gl": "^4.7.1",
    "memoizerific": "^1.11.3",
    "prism-react-renderer": "^2.4.1",
    "prop-types": "^15.8.1",
    "rbush": "^4.0.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^6.30.3",
    "remark-gfm": "^4.0.1",
    "sass": "^1.97.3",
    "sonner": "^2.0.7",
    "string-width": "^4.2.3",
    "tailwind-merge": "^2.6.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "4.1.3",
    "@eslint/js": "^9.39.3",
    "@fullhuman/postcss-purgecss": "^6.0.0",
    "@storybook/addon-a11y": "^10.2.13",
    "@storybook/addon-docs": "^10.2.13",
    "@storybook/addon-links": "^10.2.13",
    "@storybook/react": "^10.2.13",
    "@storybook/react-vite": "^10.2.13",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/mapbox__mapbox-gl-draw": "^1.4.9",
    "@types/node": "^20.19.35",
    "@types/rbush": "^4.0.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.1",
    "@vitest/ui": "^1.6.1",
    "autoprefixer": "^10.4.27",
    "chromatic": "^13.3.5",
    "eslint": "^9.39.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-storybook": "^10.2.13",
    "eslint-plugin-tailwindcss": "^3.18.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^24.1.3",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "react-map-gl": "^7.1.9",
    "storybook": "^10.2.13",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "turbo": "^2.8.12",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^5.4.21",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^1.6.1"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "pnpm run lint"
    ],
    "*.{css,scss,json,md}": [
      "pnpm run format"
    ]
  },
  "volta": {
    "node": "24.12.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": ">=0.25.0"
    }
  }
}
