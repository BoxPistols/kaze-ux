{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "AIコードレビュー設定ファイル",
  "language": "ja",
  "reviewers": {
    "openai": {
      "enabled": true,
      "model": "gpt-4o-mini",
      "temperature": 0.3,
      "maxTokens": 500,
      "maxFilesPerReview": 5,
      "maxFileSizeBytes": 5000
    },
    "github-copilot": {
      "enabled": false,
      "level": "detailed"
    },
    "custom-rules": {
      "enabled": true,
      "rulesFile": "AI_DEVELOPMENT_RULES.md"
    }
  },
  "reviewTriggers": {
    "onPrOpen": true,
    "onPrUpdate": true,
    "onRequest": true
  },
  "reviewFormat": {
    "language": "japanese",
    "style": "constructive",
    "includeSuggestions": true,
    "severityLevels": ["error", "warning", "info", "suggestion"]
  },
  "integration": {
    "postAsComment": true,
    "createReview": false,
    "requestChangesOnCritical": false,
    "autoApproveOnPass": false
  },
  "rules": {
    "typescript": {
      "noAnyType": {
        "enabled": true,
        "severity": "error",
        "message": "any型の使用は禁止されています"
      },
      "noUnusedVars": {
        "enabled": true,
        "severity": "warning"
      }
    },
    "react": {
      "noReactFC": {
        "enabled": true,
        "severity": "warning",
        "message": "React.FCの使用は推奨されません"
      },
      "preferFunctionComponents": {
        "enabled": true,
        "severity": "info"
      }
    },
    "mui": {
      "useNewGridApi": {
        "enabled": true,
        "severity": "error",
        "message": "古いGrid API（Grid item）ではなく、新しいAPI（Grid size={{ ... }}）を使用してください"
      }
    },
    "general": {
      "noConsoleLog": {
        "enabled": true,
        "severity": "warning",
        "excludePatterns": ["*.test.*", "*.stories.*"],
        "message": "console.logを削除してください"
      },
      "noEmoji": {
        "enabled": true,
        "severity": "warning",
        "message": "絵文字の使用は禁止されています"
      },
      "japaneseComments": {
        "enabled": true,
        "severity": "info",
        "message": "コメントは日本語で記述してください"
      }
    }
  },
  "excludePaths": [
    "node_modules/**",
    "dist/**",
    "build/**",
    "coverage/**",
    "storybook-static/**",
    "*.min.js",
    "*.d.ts"
  ],
  "rateLimiting": {
    "maxReviewsPerHour": 10,
    "delayBetweenReviewsMs": 1000
  },
  "notifications": {
    "slackWebhook": "",
    "emailRecipients": []
  },
  "autoFix": {
    "enabled": true,
    "commands": {
      "/fix all": {
        "description": "全ての問題を自動修正",
        "actions": ["typescript", "lint", "security", "performance"]
      },
      "/fix typescript": {
        "description": "TypeScript型エラーを修正",
        "model": "gpt-4o",
        "targets": ["any-type", "type-mismatch", "missing-property"]
      },
      "/fix lint": {
        "description": "ESLint/Prettierで修正",
        "tools": ["eslint --fix", "prettier --write"]
      },
      "/fix security": {
        "description": "セキュリティ脆弱性を修正",
        "tools": ["pnpm audit --fix"]
      },
      "/fix performance": {
        "description": "パフォーマンス分析",
        "checks": ["useEffect-deps", "inline-objects", "missing-memo"]
      },
      "/resolve-conflict": {
        "description": "マージコンフリクトを解決",
        "model": "gpt-4o",
        "strategy": "merge-both-changes"
      }
    },
    "autoCommit": true,
    "commitMessagePrefix": "[AI Auto Fix]"
  }
}
