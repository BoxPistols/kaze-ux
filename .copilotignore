# GitHub Copilot 除外設定
# このファイルに記載されたパターンに一致するファイルは、
# GitHub Copilotの参照・学習対象から除外されます

# 依存関係
node_modules/
.pnpm-store/

# ビルド成果物
dist/
build/
storybook-static/
coverage/
html/

# 環境設定・シークレット
.env
.env.*
*.local
.secrets/
credentials/

# IDE設定
.idea/
.vscode/settings.json

# キャッシュ
.cache/
.turbo/
*.log

# テスト関連（重複学習を避ける）
__snapshots__/

# 自動生成ファイル
*.min.js
*.min.css
*.map
*.d.ts

# ロック・設定ファイル
pnpm-lock.yaml
package-lock.json
yarn.lock

# ドキュメント（コード生成に不要）
*.md
!AI_DEVELOPMENT_RULES.md
!README.md

# 画像・アセット
*.png
*.jpg
*.jpeg
*.gif
*.svg
*.ico
*.woff
*.woff2
*.ttf
*.eot

# その他
.git/
.github/workflows/*.yml
